{
  "expo": {
    "name": "Player Nation",
    "slug": "player-nation",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/PlayerNation.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.hemanth.playernation",
      "predictiveBackGestureEnabled": false,
      "splash": {
        "image": "./assets/PlayerNation.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "69506427-bac0-4d24-b7eb-ab6bcf520bbd"
      }
    }
  }
}
