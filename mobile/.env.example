# ─── Backend API URL ──────────────────────────────────────────────────────────
# For Android Emulator: http://10.0.2.2:3000
# For physical device:  http://<YOUR_PC_LOCAL_IP>:3000  (e.g. http://192.168.1.5:3000)
# The app auto-discovers the backend on the 192.168.1.x subnet,
# but setting this explicitly speeds up the initial connection.
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
